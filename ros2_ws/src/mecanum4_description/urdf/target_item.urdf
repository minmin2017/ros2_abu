<?xml version="1.0"?>
<robot name="target_item">

  <!-- A dummy base link to anchor the item -->
  <link name="item_base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>

  <link name="hand_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Hand.stl" scale="0.001 0.001 0.001"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Hand.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>
  <joint name="hand_joint" type="fixed">
    <parent link="item_base_link"/>
    <child link="hand_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="fist_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Fist.stl" scale="0.001 0.001 0.001"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Fist.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>
  <joint name="fist_joint" type="fixed">
    <parent link="hand_link"/>
    <child link="fist_link"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/>
  </joint>

  <link name="spear_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Spear.stl" scale="0.001 0.001 0.001"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mecanum4_description/urdf/meshes/Spear.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>
  <joint name="spear_joint" type="fixed">
    <parent link="hand_link"/>
    <child link="spear_link"/>
    <origin xyz="0.1 0.0 0.0" rpy="0 1.57 0"/>
  </joint>

</robot>

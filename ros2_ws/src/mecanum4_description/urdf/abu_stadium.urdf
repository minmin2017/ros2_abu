<?xml version="1.0"?>
<robot name="abu_stadium">
  <link name="abu_stadium_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>

    <!-- Keep the same orientation as the world model (roll +90 deg) and
         compensate mesh origin so its bottom rests near z=0 when spawned. -->
    <visual name="base_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/base_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="base_beige">
        <color rgba="1.0 0.898 0.8 1.0"/>
      </material>
    </visual>

    <visual name="forest_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/forest_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="forest_green">
        <color rgba="0.13 0.66 0.33 1.0"/>
      </material>
    </visual>

    <visual name="forest2_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/forest2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="forest2_green">
        <color rgba="0.13 0.66 0.33 1.0"/>
      </material>
    </visual>

    <visual name="spearhead_rack_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/spearhead_rack_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="rack_brown">
        <color rgba="0.545 0.353 0.169 1.0"/>
      </material>
    </visual>

    <visual name="staff_rack_1_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/staff_rack_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="rack_brown_2">
        <color rgba="0.545 0.353 0.169 1.0"/>
      </material>
    </visual>

    <visual name="staff_rack_2_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/staff_rack_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="rack_brown_3">
        <color rgba="0.545 0.353 0.169 1.0"/>
      </material>
    </visual>

    <visual name="tic_tac_toe_rack_visual">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/tic_tac_toe_rack_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision name="base_collision">
      <origin xyz="0 0 -1.2049" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://mecanum4_description/meshes/abu_stadium/base_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <gazebo>
    <static>true</static>
  </gazebo>
</robot>

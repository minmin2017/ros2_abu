[Unit]
Description=YDLidar ROS2 Driver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=minmin
WorkingDirectory=/home/minmin/ros2_ws
ExecStartPre=/bin/sleep 3
ExecStart=/home/minmin/ros2_ws/start_ydlidar.sh
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
